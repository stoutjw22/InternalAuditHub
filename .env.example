# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-50-char-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL strongly recommended) ────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/internalaudithub

# ── CORS (frontend origins allowed to call the API) ───────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Azure AD / Entra ID (leave blank to disable SSO) ─────────────────────────
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ── Email ─────────────────────────────────────────────────────────────────────
# Use console backend in dev; swap for SMTP in production.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── File Storage ──────────────────────────────────────────────────────────────
MEDIA_URL=/media/
MEDIA_ROOT=media/

# ── Production only (uncomment when deploying) ────────────────────────────────
# SECURE_HSTS_SECONDS=31536000
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
